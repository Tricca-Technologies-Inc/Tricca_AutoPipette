# A protocol for making prime panel A 10mL *)

# Acetylornithine *)
pipette 50.0 --extra_air --after_air --src_row 0 --src_col 0 manu1 KIT1 --dispense_vol 50.0 --tipbox tipbox --prewet 1 

# Asymmetric dimethylarginine *)
pipette 50.0 --extra_air --after_air --src_row 0 --src_col 1 manu1 KIT1 --dispense_vol 50.0 --tipbox tipbox --prewet 1 

# Carnosine *)
